#!/usr/bin/env bash
# -------------------------------------------------------------------
# path:        ~/.config/.pre-commit-hook
# description: blocks commits containing sensitive patterns
# install:     cp .pre-commit-hook .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# -------------------------------------------------------------------

RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
NC='\033[0m'

REPO_ROOT=$(git rev-parse --show-toplevel)

# ── Allowlist ─────────────────────────────────────────────────────
# Files listed in .hook-allowlist skip CONTENT scanning only.
# Path-based blocks (stripe/, gh/) are NEVER skippable.
ALLOWLIST_FILE="$REPO_ROOT/.hook-allowlist"

is_allowlisted() {
  local file="$1"
  [ -f "$ALLOWLIST_FILE" ] || return 1
  grep -qxF "$file" "$ALLOWLIST_FILE" 2>/dev/null
}

# ── 1) Block staged files inside sensitive directories ────────────
BLOCKED_DIRS='(^stripe/|^gh/)'
BLOCKED_DIR_FILES=$(git diff --cached --name-only | grep -iE "$BLOCKED_DIRS" || true)
if [ -n "$BLOCKED_DIR_FILES" ]; then
  echo -e "${RED}BLOCKED: You are about to commit files from a sensitive directory${NC}"
  echo "These files must NEVER enter git history."
  echo -e "${YELLOW}Files:${NC}"
  echo "$BLOCKED_DIR_FILES" | while read -r f; do
    echo -e "  ${CYAN}$f${NC}"
  done
  echo ""
  echo "Run: git reset HEAD <file>"
  exit 1
fi

# ── 2) Block sensitive paths (credentials, env backups, .env) ─────
BLOCKED_PATHS='(credentials|env\.bak|\.env)'
BLOCKED_FILES=$(git diff --cached --name-only | grep -iE "$BLOCKED_PATHS" || true)
if [ -n "$BLOCKED_FILES" ]; then
  echo -e "${RED}BLOCKED: Staged files match sensitive path patterns${NC}"
  echo -e "${YELLOW}Files:${NC}"
  echo "$BLOCKED_FILES" | while read -r f; do
    echo -e "  ${CYAN}$f${NC}"
  done
  echo ""
  echo "Run: git reset HEAD <file>"
  exit 1
fi

# ── 3) Scan staged content for sensitive patterns ────────────────
PATTERNS=(
  'PRIVATE KEY'
  'BEGIN RSA'
  'BEGIN EC'
  'BEGIN DSA'
  'BEGIN OPENSSH'
  'password\s*[:=]'
  'passwd\s*[:=]'
  'secret\s*[:=]'
  'api_key\s*[:=]'
  'api[-_]?secret'
  'access_token'
  'auth_token'
  'client[_-]secret'
  'tenant[_-]id'
  'AWS_ACCESS_KEY'
  'AWS_SECRET'
  'AKIA[0-9A-Z]{16}'
  'ghp_[a-zA-Z0-9]{36}'
  'sk-[a-zA-Z0-9]{48}'
  'xox[bpoas]-[0-9a-zA-Z]+'
  'mongodb(\+srv)?://[^\s]+'
  'postgres(ql)?://[^\s]+'
  'mysql://[^\s]+'
  'jdbc:[^\s]+'
  'spring\.datasource\.'
  'AZURE_'
  'MSAL_'
  'sk_test_[a-zA-Z0-9]+'
  'sk_live_[a-zA-Z0-9]+'
  'pk_test_[a-zA-Z0-9]+'
  'pk_live_[a-zA-Z0-9]+'
)

COMBINED=$(IFS='|'; echo "${PATTERNS[*]}")

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM || true)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}Pre-commit check passed.${NC}"
  exit 0
fi

FOUND_ISSUES=false

for file in $STAGED_FILES; do
  # Skip allowlisted files (documentation that references patterns)
  if is_allowlisted "$file"; then
    continue
  fi

  MATCHES=$(git diff --cached -U0 -- "$file" \
    | grep '^+' \
    | grep -v '^+++' \
    | grep -iE "$COMBINED" \
    || true)

  if [ -n "$MATCHES" ]; then
    if [ "$FOUND_ISSUES" = false ]; then
      echo -e "${RED}BLOCKED: Potential sensitive data detected in staged changes${NC}"
      echo ""
      FOUND_ISSUES=true
    fi

    echo -e "  ${CYAN}$file${NC}"
    echo "$MATCHES" | head -5 | while read -r line; do
      echo -e "    ${YELLOW}$line${NC}"
    done
    echo ""
  fi
done

if [ "$FOUND_ISSUES" = true ]; then
  echo "If this is a false positive, commit with: git commit --no-verify"
  echo "But think twice. Think three times."
  exit 1
fi

echo -e "${GREEN}Pre-commit check passed.${NC}"
exit 0
