# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  layout.skhdrc — Stack Layout Controls                                     ║
# ║  path: ~/.config/skhd/modules/stack/layout.skhdrc                          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
#
# STACK LAYOUT
# ────────────
# Float snaps for pulling reference windows out of the stack.
# --toggle float + --grid works with SIP (operates on floating windows only).
# Same key unfloats the window back into the stack.


# ── Float: Center ─────────────────────────────────────────────────────────
# Hyper+D: pop window to centered float (50% screen) or push back into stack
hyper - d : yabai -m window --toggle float; yabai -m window --grid 4:4:1:1:2:2

# ── Float: Left Half ──────────────────────────────────────────────────
# Hyper+W: snap float to left half
hyper - w : yabai -m window --toggle float; yabai -m window --grid 1:2:0:0:1:1

# ── Float: Right Half ────────────────────────────────────────────────────
# Hyper+E: snap float to right half
hyper - e : yabai -m window --toggle float; yabai -m window --grid 1:2:1:0:1:1



# ── SIP-GATED (not available) ────────────────────────────────────────────
# window --space, space --focus, scratchpad, opacity, animations, shadows
# all require partially disabled SIP. Not usable on this machine.


# FREE HYPER KEYS (available for future use):
#   b, m, n, x, y, z
